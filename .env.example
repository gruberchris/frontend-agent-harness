# Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit your actual secrets.

# GitHub OAuth token with Copilot access.
# IMPORTANT: Classic PATs are NOT supported by the Copilot API.
# Option 1 (recommended): Leave this blank and run `gh auth login` — the harness
#   will call `gh auth token` automatically.
# Option 2: Set this to the output of `gh auth token` after authenticating.
GITHUB_TOKEN=

# Azure OpenAI provider — set ONE of the following (bearer token takes precedence):
#
# JWT bearer token for non-standard Azure-compatible endpoints (e.g. CHR's AI router).
# When set, requests use `Authorization: Bearer <token>`.
AZURE_OPENAI_BEARER_TOKEN=
#
# Standard Azure OpenAI API key.
# When set (and AZURE_OPENAI_BEARER_TOKEN is not), requests use the `api-key` header.
AZURE_OPENAI_API_KEY=
