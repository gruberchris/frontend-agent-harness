# Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit your actual secrets.

# GitHub OAuth token with Copilot access.
# IMPORTANT: Classic PATs are NOT supported by the Copilot API.
# Option 1 (recommended): Leave this blank and run `gh auth login` — the harness
#   will call `gh auth token` automatically.
# Option 2: Set this to the output of `gh auth token` after authenticating.
GITHUB_TOKEN=
